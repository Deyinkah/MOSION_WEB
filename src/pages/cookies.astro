---
export const prerender = true;
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Cookies &amp; Storage — MOSION"
  description="Cookies and browser storage used on mosion.app."
  canonical="https://mosion.app/cookies"
  logoOnly={true}
  bodyClass="policy-page"
  css={["/privacy.css"]}
>
  <main class="policy-page-shell">
    <article class="policy-article" aria-labelledby="cookiesTitle">
      <header class="policy-intro">
        <h1 class="hero-title" id="cookiesTitle">Cookies</h1>
        <div class="policy-meta">Updated April 5, 2026</div>
        <p class="hero-copy">
          MOSION uses limited first-party browser storage on <span class="inline-code">mosion.app</span> to support notice frequency control and returning-user routing. No third-party advertising or cross-site tracking cookies are used.
        </p>
        <ul class="policy-toc" aria-label="Cookies page contents">
          <li><a href="#storage">01 Storage In Use</a></li>
          <li><a href="#browser-settings">02 If Cookies Are Blocked</a></li>
          <li><a href="#contact">03 Contact</a></li>
        </ul>
      </header>

      <section class="policy-section" id="storage" aria-labelledby="storageHeading">
        <div class="policy-section-label">01 Storage In Use</div>
        <h2 id="storageHeading">Cookies and browser storage on mosion.app</h2>
        <p>The following first-party items are currently in use on <span class="inline-code">mosion.app</span>.</p>
        <div class="storage-list">
          <article class="storage-item">
            <h3 class="storage-item-title">Cookie / local storage: mosion_prototype_notice_seen_v1</h3>
            <p>Used to remember that the public site preview notice has already been shown on that browser, so the same notice is not repeated unnecessarily. The public privacy page is intentionally excluded from that notice.</p>
            <p>Type: first-party cookie plus local-storage fallback. Retention: up to 12 months. Purpose: notice frequency control.</p>
          </article>
        </div>
      </section>

      <section class="policy-section" id="browser-settings" aria-labelledby="browserHeading">
        <div class="policy-section-label">02 If Cookies Are Blocked</div>
        <h2 id="browserHeading">If cookies are blocked</h2>
        <p>The public site can still load if cookies are blocked. In practical terms, disabling cookies mainly removes the browser memory layer that helps MOSION avoid repeating notices. It does not prevent the site from loading or functioning.</p>
      </section>

      <section class="policy-section" id="contact" aria-labelledby="contactHeading">
        <div class="policy-section-label">03 Contact</div>
        <h2 id="contactHeading">Questions</h2>
        <p>For cookies and storage questions related to <span class="inline-code">mosion.app</span>, contact <a class="contact-link" href="mailto:support@mosion.app">support@mosion.app</a>.</p>
      </section>
    </article>
  </main>
</MainLayout>
