---
export const prerender = true;
import { getCollection, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.excerpt,
  image: post.data.image,
  author: {
    "@type": "Person",
    name: post.data.author,
  },
  publisher: {
    "@type": "Organization",
    name: "MOSION",
    url: "https://www.mosion.app",
  },
  datePublished: post.data.publishedAt,
  url: `https://www.mosion.app/blog/${post.id}`,
};
---

<MainLayout
  title={`${post.data.title} — MOSION Blog`}
  description={post.data.excerpt}
  canonical={`https://www.mosion.app/blog/${post.id}`}
  ogTitle={post.data.title}
  ogDescription={post.data.excerpt}
  ogImage={post.data.image}
  logoOnly={true}
  bodyClass="blog-page"
  css={["/blog.css"]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <main class="blog-shell blog-article-page">
    <section
      class="blog-article-hero"
      style={`background-image: url('${post.data.image}')`}
    >
      <div class="blog-article-hero__overlay">
        <div class="blog-article-hero__content">
          <a href="/blog" class="blog-breadcrumb-link">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M13 7H1M1 7L7 1M1 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Back to All
          </a>
          <p class="blog-eyebrow">{post.data.category}</p>
          <h1>{post.data.title}</h1>
          <div class="blog-article-meta">
            <span>{post.data.author}</span>
            <span>{post.data.publishedAt}</span>
            <span>{post.data.readingTime}</span>
          </div>
          <button class="blog-share-btn" id="blogShareBtn" type="button" aria-label="Share this article">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
            </svg>
            <span id="blogShareLabel">Share</span>
          </button>

          <script is:inline>
            (function () {
              var btn = document.getElementById("blogShareBtn");
              var label = document.getElementById("blogShareLabel");
              if (!btn) return;
              btn.addEventListener("click", async function () {
                var url = window.location.href;
                var title = document.querySelector("h1") ? document.querySelector("h1").textContent.trim() : document.title;
                try {
                  await navigator.share({ title: title, url: url });
                } catch (e) {
                  if (e.name !== "AbortError") {
                    await navigator.clipboard.writeText(url);
                    label.textContent = "Copied!";
                    setTimeout(function () { label.textContent = "Share"; }, 2000);
                  }
                }
              });
            })();
          </script>
        </div>
      </div>
    </section>

    <div class="blog-article-body-wrap">
      <div class="blog-article-body">
        <Content />
      </div>

      <div class="blog-article-cta">
        <div>
          <h3>Join Waitlist</h3>
          <p>Drop your email and you'll be among the first through the door when we open.</p>
        </div>
        <form class="blog-waitlist-form" id="blogWaitlistForm" novalidate>
          <input type="email" name="email" placeholder="Enter your email" class="blog-waitlist-input" required />
          <button type="submit" class="blog-primary-button">Join Waitlist</button>
          <p class="blog-waitlist-msg" id="blogWaitlistMsg" hidden></p>
        </form>
      </div>

      <script is:inline>
        (function () {
          var form = document.getElementById("blogWaitlistForm");
          var msg = document.getElementById("blogWaitlistMsg");
          if (!form) return;
          form.addEventListener("submit", async function (e) {
            e.preventDefault();
            var email = form.email.value.trim();
            var btn = form.querySelector("button[type='submit']");
            btn.disabled = true;
            btn.textContent = "Joining…";
            msg.hidden = true;
            try {
              var res = await fetch("/api/waitlist", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email: email, source: "blog" }),
              });
              var data = await res.json().catch(function () { return {}; });
              if (res.ok) {
                form.reset();
                msg.textContent = "You're on the list! Check your inbox.";
                msg.className = "blog-waitlist-msg blog-waitlist-msg--success";
                btn.textContent = "Joined!";
              } else {
                throw new Error(data.message || "Something went wrong.");
              }
            } catch (err) {
              msg.textContent = err.message || "Something went wrong. Try again.";
              msg.className = "blog-waitlist-msg blog-waitlist-msg--error";
              btn.disabled = false;
              btn.textContent = "Join Waitlist";
            }
            msg.hidden = false;
          });
        })();
      </script>
    </div>
  </main>
</MainLayout>
