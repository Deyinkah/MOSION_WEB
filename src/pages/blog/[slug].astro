---
export const prerender = true;
import { getCollection, render } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.excerpt,
  image: post.data.image,
  author: {
    "@type": "Person",
    name: post.data.author,
  },
  publisher: {
    "@type": "Organization",
    name: "MOSION",
    url: "https://www.mosion.app",
  },
  datePublished: post.data.publishedAt,
  url: `https://www.mosion.app/blog/${post.id}`,
};
---

<MainLayout
  title={`${post.data.title} — MOSION Blog`}
  description={post.data.excerpt}
  canonical={`https://www.mosion.app/blog/${post.id}`}
  ogTitle={post.data.title}
  ogDescription={post.data.excerpt}
  ogImage={post.data.image}
  logoOnly={true}
  bodyClass="blog-page"
  css={["/blog.css"]}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <main class="blog-shell blog-article-page">
    <section
      class="blog-article-hero"
      style={`background-image: url('${post.data.image}')`}
    >
      <div class="blog-article-hero__overlay">
        <div class="blog-article-hero__content">
          <a href="/blog" class="blog-breadcrumb-link">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M13 7H1M1 7L7 1M1 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Back to All
          </a>
          <p class="blog-eyebrow">{post.data.category}</p>
          <h1>{post.data.title}</h1>
          <div class="blog-article-meta">
            <span>{post.data.author}</span>
            <span>{post.data.publishedAt}</span>
            <span>{post.data.readingTime}</span>
          </div>
          <div class="blog-share-wrap">
            <button class="blog-share-btn" id="blogShareBtn" type="button" aria-label="Share this article">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
              Share
            </button>
            <div class="blog-share-menu" id="blogShareMenu" hidden>
              <button class="blog-share-option" id="shareWhatsApp" type="button">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
                WhatsApp
              </button>
              <button class="blog-share-option" id="shareX" type="button">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2H21.5l-7.114 8.13L22.75 22h-6.547l-5.126-7.092L4.871 22H1.613l7.608-8.696L1.25 2h6.713l4.633 6.463L18.244 2Zm-1.142 18.067h1.804L6.978 3.838H5.043l12.059 16.229Z"/></svg>
                Post on X
              </button>
              <button class="blog-share-option" id="shareCopy" type="button">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                <span id="shareCopyLabel">Copy link</span>
              </button>
            </div>
          </div>

          <script is:inline>
            (function () {
              var btn = document.getElementById("blogShareBtn");
              var menu = document.getElementById("blogShareMenu");
              if (!btn || !menu) return;

              btn.addEventListener("click", function (e) {
                e.stopPropagation();
                var open = menu.hidden;
                menu.hidden = !open;
              });

              document.addEventListener("click", function () {
                menu.hidden = true;
              });

              menu.addEventListener("click", function (e) { e.stopPropagation(); });

              document.getElementById("shareWhatsApp").addEventListener("click", function () {
                var url = encodeURIComponent(window.location.href);
                var text = encodeURIComponent(document.querySelector("h1").textContent + " — MOSION Blog");
                window.open("https://wa.me/?text=" + text + "%20" + url, "_blank");
                menu.hidden = true;
              });

              document.getElementById("shareX").addEventListener("click", function () {
                var url = encodeURIComponent(window.location.href);
                var text = encodeURIComponent(document.querySelector("h1").textContent);
                window.open("https://x.com/intent/tweet?text=" + text + "&url=" + url, "_blank");
                menu.hidden = true;
              });

              document.getElementById("shareCopy").addEventListener("click", async function () {
                await navigator.clipboard.writeText(window.location.href);
                document.getElementById("shareCopyLabel").textContent = "Copied!";
                setTimeout(function () {
                  document.getElementById("shareCopyLabel").textContent = "Copy link";
                  menu.hidden = true;
                }, 1500);
              });
            })();
          </script>
        </div>
      </div>
    </section>

    <div class="blog-article-body-wrap">
      <div class="blog-article-body">
        <Content />
      </div>

      <div class="blog-article-cta">
        <div>
          <h3>Join Waitlist</h3>
          <p>Drop your email and you'll be among the first through the door when we open.</p>
        </div>
        <form class="blog-waitlist-form" id="blogWaitlistForm" novalidate>
          <input type="email" name="email" placeholder="Enter your email" class="blog-waitlist-input" required />
          <button type="submit" class="blog-primary-button">Join Waitlist</button>
          <p class="blog-waitlist-msg" id="blogWaitlistMsg" hidden></p>
        </form>
      </div>

      <script is:inline>
        (function () {
          var form = document.getElementById("blogWaitlistForm");
          var msg = document.getElementById("blogWaitlistMsg");
          if (!form) return;
          form.addEventListener("submit", async function (e) {
            e.preventDefault();
            var email = form.email.value.trim();
            var btn = form.querySelector("button[type='submit']");
            btn.disabled = true;
            btn.textContent = "Joining…";
            msg.hidden = true;
            try {
              var res = await fetch("/api/waitlist", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email: email, source: "blog" }),
              });
              var data = await res.json().catch(function () { return {}; });
              if (res.ok) {
                form.reset();
                msg.textContent = "You're on the list! Check your inbox.";
                msg.className = "blog-waitlist-msg blog-waitlist-msg--success";
                btn.textContent = "Joined!";
              } else {
                throw new Error(data.message || "Something went wrong.");
              }
            } catch (err) {
              msg.textContent = err.message || "Something went wrong. Try again.";
              msg.className = "blog-waitlist-msg blog-waitlist-msg--error";
              btn.disabled = false;
              btn.textContent = "Join Waitlist";
            }
            msg.hidden = false;
          });
        })();
      </script>
    </div>
  </main>
</MainLayout>
