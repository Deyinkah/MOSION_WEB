---
interface Props {
  logoOnly?: boolean;
}
const { logoOnly = false } = Astro.props;
---

{logoOnly ? (
  <nav class="site-nav site-nav-logo-only" aria-label="Primary">
    <a href="/" class="logo">
      <img src="/logo-wordmark.png" alt="MOSION" class="logo-wordmark" width="168" height="20" />
    </a>
  </nav>
) : (
  <nav class="site-nav" aria-label="Primary">
    <a href="/" class="logo">
      <img src="/logo-wordmark.png" alt="MOSION" class="logo-wordmark" width="168" height="20" />
    </a>
    <div class="nav-r">
      <a href="https://www.mosion.app/signin" class="nav-signin-btn">Sign In</a>
    </div>
  </nav>
)}
