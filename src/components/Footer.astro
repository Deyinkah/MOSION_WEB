---
interface Props {
  currentPath?: string;
}
const { currentPath = "/" } = Astro.props;

const isAbout = currentPath === "/about";
const isBlog = currentPath.startsWith("/blog");
const isPrivacy = currentPath === "/privacy";
const isAccessibility = currentPath === "/accessibility";
---

<footer class="site-footer">
  <div class="footer-brand">
    <a href="/" class="footer-logo">
      <img src="/logo-wordmark.png" alt="Mosion" class="footer-logo-image footer-logo-wordmark" width="168" height="20" />
      <img src="/logo-new.jpeg" alt="" aria-hidden="true" class="footer-logo-image footer-logo-new" />
    </a>
    <div class="footer-mission">Mosion is building the infrastructure for African cinema distribution, starting in your pocket.</div>
    <div class="footer-social" aria-label="Mosion social links">
      <a href="https://www.linkedin.com/company/mosionhq" class="footer-social-link" aria-label="Follow Mosion on LinkedIn">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M6.94 5a2 2 0 1 1-4-.002 2 2 0 0 1 4 .002zM7 8.48H3V21h4V8.48zm6.32 0H9.34V21h3.94v-6.57c0-3.66 4.77-4 4.77 0V21H22v-7.93c0-6.17-7.06-5.94-8.72-2.91l.04-1.68z" fill="currentColor"/>
        </svg>
      </a>
      <a href="https://x.com/mosionhq" class="footer-social-link" aria-label="Follow Mosion on X">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M18.244 2H21.5l-7.114 8.13L22.75 22h-6.547l-5.126-7.092L4.871 22H1.613l7.608-8.696L1.25 2h6.713l4.633 6.463L18.244 2Zm-1.142 18.067h1.804L6.978 3.838H5.043l12.059 16.229Z" fill="currentColor"/>
        </svg>
      </a>
      <a href="https://www.instagram.com/mosionhq" class="footer-social-link" aria-label="Follow Mosion on Instagram">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <rect x="3.5" y="3.5" width="17" height="17" rx="4.5" fill="none" stroke="currentColor" stroke-width="1.7"/>
          <circle cx="12" cy="12" r="4.1" fill="none" stroke="currentColor" stroke-width="1.7"/>
          <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor"/>
        </svg>
      </a>
    </div>
  </div>
  <nav class="footer-nav" aria-label="Footer">
    <div class="footer-group">
      <div class="footer-heading">Platform</div>
      <ul class="footer-list">
        <li><a href="/#how">How it works</a></li>
        <li><a href="/#download">Join Waitlist</a></li>
      </ul>
    </div>
    <div class="footer-group">
      <div class="footer-heading">Products</div>
      <ul class="footer-list">
        <li><a href="https://www.mosion.app/browse">Browse</a></li>
        <li><a href="https://studio.mosion.app">Mosion Studio</a></li>
        <li><a href="/filmportal">Film Portal</a></li>
      </ul>
    </div>
    <div class="footer-group">
      <div class="footer-heading">Company</div>
      <ul class="footer-list">
        <li><a href="/blog" aria-current={isBlog ? "page" : undefined}>Blog</a></li>
        <li><a href="/about" aria-current={isAbout ? "page" : undefined}>About</a></li>
        <li><a href="mailto:support@mosion.app">Contact</a></li>
      </ul>
    </div>
    <div class="footer-group">
      <div class="footer-heading">Legal</div>
      <ul class="footer-list">
        <li><a href="/privacy" aria-current={isPrivacy ? "page" : undefined}>Privacy</a></li>
        <li><a href="/cookies">Cookies</a></li>
        <li><a href="/terms">Terms</a></li>
        <li><a href="/accessibility" aria-current={isAccessibility ? "page" : undefined}>Accessibility</a></li>
      </ul>
    </div>
  </nav>
  <div class="footer-meta">
    <div class="footer-copy">&copy; 2026 Mosion. All rights reserved.<span class="footer-rc-inline"> RC No. 9433196</span></div>
    <div class="footer-rc">RC No. 9433196</div>
  </div>
</footer>

<div class="coming-soon-modal" id="comingSoonModal" hidden>
  <div class="coming-soon-backdrop" data-modal-close></div>
  <div
    class="coming-soon-dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="comingSoonTitle"
    aria-describedby="comingSoonCopy"
  >
    <button type="button" class="coming-soon-close" data-modal-close aria-label="Close popup">
      <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
        <path d="M3.5 3.5 12.5 12.5M12.5 3.5 3.5 12.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <h3 class="coming-soon-title" id="comingSoonTitle">Coming soon</h3>
    <p class="coming-soon-copy" id="comingSoonCopy">This page is being prepared and will be available soon.</p>
  </div>
</div>

<aside
  class="prototype-notice"
  id="prototypeNotice"
  hidden
  aria-live="polite"
  aria-labelledby="prototypeNoticeTitle"
  aria-describedby="prototypeNoticeCopy"
>
  <button type="button" class="prototype-notice-close" id="prototypeNoticeClose" aria-label="Dismiss catalog preview notice">
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
      <path d="M3.5 3.5l9 9M12.5 3.5l-9 9" />
    </svg>
  </button>
  <div class="prototype-notice-kicker">Preview Notice</div>
  <div class="prototype-notice-title" id="prototypeNoticeTitle">Catalog preview shown</div>
  <p class="prototype-notice-copy" id="prototypeNoticeCopy">Banner artwork and sample film titles shown are for interface demonstration only. Final catalog will reflect licensed partner content.</p>
</aside>
