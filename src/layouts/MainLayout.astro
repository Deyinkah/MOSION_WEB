---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  bodyClass?: string;
  logoOnly?: boolean;
  extraHead?: string;
  css?: string[];
}

const {
  title,
  description,
  canonical,
  ogTitle,
  ogDescription,
  ogImage = "https://www.mosion.app/og-image.jpg",
  bodyClass = "",
  logoOnly = false,
  css = [],
} = Astro.props;

const currentPath = new URL(canonical).pathname;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <script is:inline src="/scripts/desktop-mode.js"></script>
  <meta name="theme-color" content="#080808" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="MOSION" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="MOSION" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={ogTitle ?? title} />
  <meta property="og:description" content={ogDescription ?? description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="en_NG" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle ?? title} />
  <meta name="twitter:description" content={ogDescription ?? description} />
  <meta name="twitter:image" content={ogImage} />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="manifest" href="/site.webmanifest" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600;1,700&family=Space+Mono:wght@400;700&family=Outfit:wght@300;400;500;600&family=Syne:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/layout.css" />
  {css.map((href) => <link rel="stylesheet" href={href} />)}
  <slot name="head" />
</head>
<body class={bodyClass}>
  <Nav logoOnly={logoOnly} />
  <slot />
  <Footer currentPath={currentPath} />
  <script is:inline src="/scripts/site-core.js" defer></script>
  <script is:inline src="/scripts/layout.js" defer></script>
  <slot name="scripts" />
</body>
</html>
