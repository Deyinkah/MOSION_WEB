---
export interface Props {
  title: string;
  description: string;
  canonical: string;
  pageLabel: string;
}

const { title, description, canonical, pageLabel } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script is:inline src="/scripts/studio-desktop-mode.js"></script>
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/studio-privacy.css" />
</head>
<body>
  <div class="page-shell">
    <nav class="page-nav" aria-label="Studio legal page">
      <a href="https://studio.mosion.app/" class="nav-logo" aria-label="MOSION Studio home">
        <img class="nav-logo-image" src="/studio-logo-wordmark.png" alt="MOSION" />
      </a>
      <div class="page-crumb" aria-hidden="true">
        <a href="https://studio.mosion.app/" class="back-link">Home</a>
        <span>/</span>
        <span class="page-crumb-current" aria-current="page">{pageLabel}</span>
      </div>
    </nav>

    <main class="page-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-brand">
        <a href="https://studio.mosion.app/" class="footer-logo" aria-label="Mosion Studio home">
          <img class="footer-logo-image footer-logo-wordmark" src="/studio-logo-wordmark.png" alt="Mosion" />
          <img class="footer-logo-image footer-logo-new" src="/studio-logo-mobile.png" alt="" aria-hidden="true" />
        </a>
        <div class="footer-mission">Mosion Studio is the curated distribution infrastructure African cinema has always deserved.</div>
        <div class="footer-social" aria-label="Mosion social links">
          <a href="https://www.linkedin.com/company/mosionhq" class="footer-social-link" target="_blank" rel="noopener noreferrer" aria-label="Follow Mosion on LinkedIn">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M6.94 5a2 2 0 1 1-4-.002 2 2 0 0 1 4 .002zM7 8.48H3V21h4V8.48zm6.32 0H9.34V21h3.94v-6.57c0-3.66 4.77-4 4.77 0V21H22v-7.93c0-6.17-7.06-5.94-8.72-2.91l.04-1.68z" fill="currentColor"/></svg>
          </a>
          <a href="https://x.com/mosionhq" class="footer-social-link" target="_blank" rel="noopener noreferrer" aria-label="Follow Mosion on X">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M18.244 2H21.5l-7.114 8.13L22.75 22h-6.547l-5.126-7.092L4.871 22H1.613l7.608-8.696L1.25 2h6.713l4.633 6.463L18.244 2Zm-1.142 18.067h1.804L6.978 3.838H5.043l12.059 16.229Z" fill="currentColor"/></svg>
          </a>
          <a href="https://www.instagram.com/mosionhq" class="footer-social-link" target="_blank" rel="noopener noreferrer" aria-label="Follow Mosion on Instagram">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><rect x="3.5" y="3.5" width="17" height="17" rx="4.5" fill="none" stroke="currentColor" stroke-width="1.7"/><circle cx="12" cy="12" r="4.1" fill="none" stroke="currentColor" stroke-width="1.7"/><circle cx="17.2" cy="6.8" r="1.1" fill="currentColor"/></svg>
          </a>
        </div>
      </div>
      <nav class="footer-nav" aria-label="Footer">
        <div class="footer-group">
          <div class="footer-heading">Studio</div>
          <ul class="footer-list">
            <li><a href="https://studio.mosion.app/#process">Process</a></li>
            <li><a href="https://studio.mosion.app/#standards">Standards</a></li>
            <li><a href="https://studio.mosion.app/#apply">Apply</a></li>
          </ul>
        </div>
        <div class="footer-group">
          <div class="footer-heading">Company</div>
          <ul class="footer-list">
            <li><a href="https://www.mosion.app/about">About</a></li>
            <li><a href="mailto:partners@mosion.app?subject=Studio%20Support">Support</a></li>
            <li><a href="mailto:partners@mosion.app">Contact</a></li>
          </ul>
        </div>
        <div class="footer-group">
          <div class="footer-heading">Legal</div>
          <ul class="footer-list">
            <li><a href="https://studio.mosion.app/privacy" aria-current={pageLabel === 'Privacy' ? 'page' : undefined}>Privacy</a></li>
            <li><a href="https://studio.mosion.app/cookies" aria-current={pageLabel === 'Cookies' ? 'page' : undefined}>Cookies</a></li>
            <li><a href="https://studio.mosion.app/terms" aria-current={pageLabel === 'Terms' ? 'page' : undefined}>Terms</a></li>
            <li><a href="https://studio.mosion.app/accessibility" aria-current={pageLabel === 'Accessibility' ? 'page' : undefined}>Accessibility</a></li>
          </ul>
        </div>
      </nav>
      <div class="footer-meta">
        <div class="footer-copy">&copy; 2026 Mosion. All rights reserved.<span class="footer-rc-inline"> RC No. 9433196</span></div>
        <div class="footer-rc">RC No. 9433196</div>
      </div>
    </footer>
  </div>
</body>
</html>
