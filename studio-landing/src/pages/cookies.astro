---
export const prerender = true;
import StudioLegalLayout from "../layouts/StudioLegalLayout.astro";
---

<StudioLegalLayout
  title="Cookies — MOSION Studio"
  description="Cookie and browser storage policy for MOSION Studio on studio.mosion.app."
  canonical="https://studio.mosion.app/cookies"
  pageLabel="Cookies"
>
  <article class="policy-article" aria-labelledby="cookiesTitle">
    <header class="policy-intro">
      <h1 class="hero-title" id="cookiesTitle">Cookies</h1>
      <div class="policy-meta">Updated April 5, 2026</div>
      <p class="hero-copy">MOSION Studio uses limited first-party browser storage on <span class="inline-code">studio.mosion.app</span> to support sign-in continuity and notice state. No third-party advertising or cross-site tracking cookies are used.</p>
      <ul class="policy-toc" aria-label="Cookies page contents">
        <li><a href="#storage">01 Storage In Use</a></li>
        <li><a href="#browser-settings">02 If Cookies Are Blocked</a></li>
        <li><a href="#contact">03 Contact</a></li>
      </ul>
    </header>

    <section class="policy-section" id="storage" aria-labelledby="storageHeading">
      <div class="policy-section-label">01 Storage In Use</div>
      <h2 id="storageHeading">Cookies and browser storage on studio.mosion.app</h2>
      <p>The following first-party items are currently in use on <span class="inline-code">studio.mosion.app</span>.</p>
      <div class="storage-list">
        <article class="storage-item">
          <h3 class="storage-item-title">Cookie: studio_known_user</h3>
          <p>Set after a Studio sign-in has been restored or completed successfully. Used to remember that this browser has signed in before, so Studio can recognise a returning browser without storing full account data in the landing page itself.</p>
          <p>Type: first-party cookie. Retention: up to 12 months. Purpose: returning-browser recognition for Studio sign-in convenience.</p>
        </article>
        <article class="storage-item">
          <h3 class="storage-item-title">Cookie / local storage: mosion_studio_cookie_notice_seen_v1</h3>
          <p>Used on the Studio landing page to remember that you dismissed the Studio cookie information banner, so the same message is not shown repeatedly after you have already seen it.</p>
          <p>Type: first-party cookie plus local-storage fallback. Retention: up to 12 months. Purpose: banner dismissal state.</p>
        </article>
        <article class="storage-item">
          <h3 class="storage-item-title">Local storage: mosion_auth_session_v1</h3>
          <p>Used by the Studio web app after sign-in to keep the active Studio session on the current browser. Clearing browser storage or signing out removes that remembered session.</p>
          <p>Type: local storage. Retention: until sign-out or storage is cleared. Purpose: session continuity on this device.</p>
        </article>
      </div>
    </section>

    <section class="policy-section" id="browser-settings" aria-labelledby="browserHeading">
      <div class="policy-section-label">02 If Cookies Are Blocked</div>
      <h2 id="browserHeading">If cookies are blocked</h2>
      <p>The Studio landing page can still load if cookies are blocked, but some convenience behaviour may stop working. Notice dismissal state may not be remembered, and returning Studio users may stay on the landing page instead of being sent straight to sign in.</p>
      <p>Disabling cookies does not prevent the Studio landing page from loading. It mainly removes the browser memory layer that helps Studio recognise a returning browser for faster sign-in routing.</p>
    </section>

    <section class="policy-section" id="contact" aria-labelledby="contactHeading">
      <div class="policy-section-label">03 Contact</div>
      <h2 id="contactHeading">Questions</h2>
      <p>For cookies and storage questions related to <span class="inline-code">studio.mosion.app</span>, contact <a class="contact-link" href="mailto:partners@mosion.app">partners@mosion.app</a>.</p>
    </section>
  </article>
</StudioLegalLayout>
